---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Overlayer — overlay text on videos with precision.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.png" sizes="32x32"/>
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Overlayer</title>
    <script is:inline>
      if (window.location.pathname !== '/') {
        window.history.replaceState(null, '', '/');
      }
    </script>
  </head>
  <body>
    <main class="main-content">
      <slot />
    </main>
    <footer class="layout-footer">
      <p>🛡️ <strong>Privacy & Content Notice:</strong> No personal data is collected. Please ensure you only upload content you have the right to use. Your content is strictly used for processing and is permanently deleted within a week.</p>
      <p class="authorship-note">Designed and developed by <a href="https://jonsousa.dev" target="_blank" rel="noopener noreferrer">Jonathan Sousa</a> as a portfolio project showcasing modern software engineering practices. All code, UI, and infrastructure were created for demonstration purposes.
      </p>
      <p class="authorship-note"> Explore the source on
      <a href="https://github.com/jonathan-jesus/overlayer" target="_blank" rel="noopener noreferrer">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="footer-icon"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>GitHub
      </a>. Learn more about <a href="https://jonsousa.dev" target="_blank" rel="noopener noreferrer"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="footer-icon"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>my experience</a>.</p>
    </footer>
    <style>
      body {
        display: flex;
        flex-direction: column;
      }
      .main-content {
        flex: 1;
        display: flex;
        flex-direction: column;
      }
      .layout-footer {
        text-align: center;
        padding: 2rem 1rem;
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        max-width: var(--max-width-narrow);
        margin: 0 auto;
        line-height: var(--leading-relaxed);
      }
      .authorship-note {
        margin-top: 1rem;
      }
      .authorship-note a {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        text-decoration: underline;
        text-underline-offset: 2px;
        color: inherit;
      }
      .authorship-note a:hover {
        color: var(--color-text);
      }
      .footer-icon {
        flex-shrink: 0;
      }
    </style>
  </body>
</html>
