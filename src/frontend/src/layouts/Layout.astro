---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Overlayer — overlay text on videos with precision.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Overlayer</title>
    <script is:inline>
      if (window.location.pathname !== '/') {
        window.history.replaceState(null, '', '/');
      }
    </script>
  </head>
  <body>
    <main class="main-content">
      <slot />
    </main>
    <footer class="layout-footer">
      <p>🛡️ <strong>Privacy & Content Notice:</strong> No personal data is collected. Please ensure you only upload content you have the right to use. Your content is strictly used for processing and is permanently deleted within a week.</p>
    </footer>
    <style>
      body {
        display: flex;
        flex-direction: column;
      }
      .main-content {
        flex: 1;
        display: flex;
        flex-direction: column;
      }
      .layout-footer {
        text-align: center;
        padding: 2rem 1rem;
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        max-width: var(--max-width-narrow);
        margin: 0 auto;
        line-height: var(--leading-relaxed);
      }
    </style>
  </body>
</html>
